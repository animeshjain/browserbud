# BrowserBud Configuration
# Copy to .env and fill in values

# Data directory (where Claude Code runs). Defaults to ~/browse
# BROWSERBUD_DATA_DIR=~/browse

# Server port (the URL you enter in the extension). Defaults to 8989
# BROWSERBUD_PORT=8989

# Internal ttyd port (proxied through the server, not accessed directly). Defaults to 7682
# BROWSERBUD_TTYD_PORT=7682

# Log level: debug, info, warn, error (default: info)
# BROWSERBUD_LOG_LEVEL=info

# YouTube transcript APIs (optional - browser extension fetches client-side first)
SUPADATA_API_KEY=
SCRAPECREATORS_API_KEY=
